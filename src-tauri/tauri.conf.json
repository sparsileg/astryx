{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Astryx",
    "version": "0.1.0",
    "identifier": "com.astryx.dev",
    "build": {
        "frontendDist": "../src",
        "devUrl": "http://localhost:1420"
    },
    "app": {
        "windows": [
            {
                "title": "Astryx",
                "width": 1400,
                "height": 900,
                "minWidth": 1200,
                "minHeight": 800,
                "center": true,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        },
        "withGlobalTauri": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}
