{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "enables the default permissions",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "core:event:default",
        "dialog:default",
        "fs:default",
        "fs:allow-read-file",
        "fs:allow-write-file",
        "fs:allow-mkdir",
        "fs:allow-remove",
        "fs:allow-read-text-file",
        "fs:allow-write-text-file",
        "fs:scope-appdata-recursive",
        "shell:allow-open"
    ]
}
